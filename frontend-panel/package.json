		"@typescript/native-preview": "^7.0.0-dev.20260327.2",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.2",
		"jsdom": "^29.0.1",
		"msw": "^2.12.14",
		"openapi-fetch": "^0.17.0",
		"openapi-typescript": "^7.13.0",
		"vite": "^8.0.3",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.2"
	}
