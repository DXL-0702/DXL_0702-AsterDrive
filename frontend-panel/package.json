{
	"name": "frontend-panel",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"extract:pdfjs-cmaps": "node ./scripts/extract-pdfjs-cmaps.mjs",
		"predev": "bun run extract:pdfjs-cmaps",
		"dev": "vite",
		"prebuild": "bun run extract:pdfjs-cmaps",
		"build": "tsgo -b && vite build",
		"generate-api": "openapi-typescript ./generated/openapi.json -o ./src/services/api.generated.ts",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@devicon/react": "^0.0.3",
		"@fontsource-variable/geist": "^5.2.8",
		"@monaco-editor/react": "^4.7.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-virtual": "^3.13.23",
		"axios": "^1.14.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"i18next": "^25.10.10",
		"papaparse": "^5.5.3",
		"prism-react-renderer": "^2.4.1",
		"react": "^19.2.4",
		"react-arborist": "^3.4.3",
		"react-dom": "^19.2.4",
		"react-i18next": "^17.0.0",
		"react-icons": "^5.5.0",
		"react-markdown": "^10.1.0",
		"react-pdf": "^10.4.1",
		"react-router-dom": "^7.13.2",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"shadcn": "^4.1.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"xml-formatter": "^3.7.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
