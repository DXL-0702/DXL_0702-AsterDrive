{
	"name": "frontend-panel",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"extract:pdfjs-cmaps": "node ./scripts/extract-pdfjs-cmaps.mjs",
		"predev": "bun run extract:pdfjs-cmaps",
		"dev": "vite",
		"prebuild": "bun run extract:pdfjs-cmaps",
		"build": "tsgo -b && vite build",
		"generate-api": "openapi-typescript ./generated/openapi.json -o ./src/services/api.generated.ts",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:asterdrive": "playwright test e2e",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-virtual": "^3.13.24",
		"artplayer": "^5.4.0",
		"axios": "^1.15.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"i18next": "^26.0.6",
		"papaparse": "^5.5.3",
		"prism-react-renderer": "^2.4.1",
		"prismjs": "^1.30.0",
		"react": "^19.2.5",
		"react-arborist": "^3.4.3",
		"react-devicons": "^2.16.2",
		"react-dom": "^19.2.5",
		"react-i18next": "^17.0.4",
		"react-icons": "^5.6.0",
		"react-image-crop": "^11.0.10",
		"react-markdown": "^10.1.0",
		"react-pdf": "^10.4.1",
		"react-router-dom": "^7.14.1",
		"recharts": "^3.8.1",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"shadcn": "^4.3.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"xml-formatter": "^3.7.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@iconify/react": "^6.0.2",
		"@playwright/test": "^1.59.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.6.0",
		"@types/papaparse": "^5.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260420.1",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.4",
		"jsdom": "^29.0.2",
		"msw": "^2.13.4",
		"openapi-fetch": "^0.17.0",
		"openapi-typescript": "^7.13.0",
